{
  "fontFamilyBase": "\"Manrope\", system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
  "basePx": 16,
  "ratio": 1.2,
  "steps": {
    "h1": 6,
    "h2": 5,
    "h3": 4,
    "h4": 3,
    "h5": 2,
    "h6": 1,
    "bodyLg": 1,
    "body": 0,
    "caption": -1,
    "micro": -2
  },
  "lineHeights": {
    "tight": 1.05,
    "heading": 1.12,
    "body": 1.6
  },
  "colors": {
    "primary": "#181D2D",
    "secondary": "#687187",
    "soft": "#8D95A8"
  }
}
